# ============================================================
# idotmatrix-dashboard - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values to match your setup:
#
#   cp .env.example .env
#
# All variables have sensible defaults. You only need to change
# what differs from your scenario.
# ============================================================

# --- BLE Device ---

# Bluetooth name prefix of your iDotMatrix display.
# The scanner searches for devices whose name starts with this value.
# Example: if your display shows up as "IDM-12345", keep "IDM-".
DEVICE_PREFIX=IDM-

# Display resolution in pixels.
# Accepted values: 16, 32, or 64 (must match your hardware).
DISPLAY_SIZE=32

# Display brightness as a percentage.
# Accepted values: 0 (off) to 100 (maximum).
# Tip: for nighttime use, values between 10-30 are comfortable.
BRIGHTNESS=80

# --- BLE Connection ---

# Timeout in seconds to establish the Bluetooth connection.
# Increase if the device takes long to respond (e.g. far from host).
BLE_TIMEOUT=10

# BLE scan duration in seconds.
# Longer scans have a higher chance of finding the device, but are slower.
BLE_SCAN_DURATION=5

# --- Display Modes ---

# Interval in seconds between mode switches (ticker -> status -> ...).
# Example: 15 = each mode stays visible for 15 seconds before switching.
CYCLE_INTERVAL=15

# --- Data: Bitcoin ---

# Currencies to display for Bitcoin price, comma-separated.
# Uses the free CoinGecko API (no API key required).
# Examples: usd, brl, eur, gbp, jpy, cad, aud, etc.
CURRENCIES=brl,usd

# --- Webhook: Agent Monitor ---

# HTTP port for the webhook server (FastAPI).
# Other services send agent status updates via POST to this port.
# Make sure the port is not already in use by another process.
WEBHOOK_PORT=8099

# --- Logging ---

# Application log level.
# Accepted values: DEBUG, INFO, WARNING, ERROR
# Use DEBUG to troubleshoot BLE connection issues.
LOG_LEVEL=INFO
